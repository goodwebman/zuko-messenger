# ── Database ────────────────────────────────────────────────────────────────
# Postgres (docker-compose поднимает его на 5432)
DATABASE_URL="postgresql://zuko:zuko@localhost:5432/zuko?schema=public"

# ── API (apps/api) ──────────────────────────────────────────────────────────
API_PORT=4000
API_HOST=0.0.0.0
# Разрешённый origin фронта для CORS + Socket.io
WEB_ORIGIN="http://localhost:3000"

# JWT — сгенерируй свои: `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# Загрузка картинок к постам
UPLOAD_DIR="./uploads"          # куда складывать файлы (относительно apps/api)
MAX_UPLOAD_MB=5                 # лимит размера одного файла
API_PUBLIC_URL="http://localhost:4000"  # базовый URL для ссылок на /uploads/*

# ── Web (apps/web) ──────────────────────────────────────────────────────────
# Публичные — уходят в браузер
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_SOCKET_URL="http://localhost:4000"
